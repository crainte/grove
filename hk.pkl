amends "package://github.com/jdx/hk/releases/download/v1.43.0/hk@1.43.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.43.0/hk@1.43.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
    ["rustfmt"] = Builtins.rustfmt
    ["clippy"] {
        glob = "*.rs"
        check = "cargo clippy -- -D warnings"
    }
}

local testers = new Mapping<String, Step> {
    ["cargo-test"] {
        glob = "*.rs"
        check = "cargo test"
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = linters
    }
    ["fix"] {
        fix = true
        steps = linters
    }
    ["check"] {
        steps = linters
    }
    ["pre-push"] {
        steps = testers
    }
}
